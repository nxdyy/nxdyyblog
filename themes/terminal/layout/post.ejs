<%
var post = page;
var dateStr = post.date ? post.date.format('YYYY-MM-DD HH:mm') : '';
var categories = [];
if (post.categories && post.categories.length) {
  post.categories.forEach(function(cat) { categories.push(cat.name); });
}
var categoryStr = categories.length ? categories.join(', ') : 'uncategorized';

var tags = [];
if (post.tags && post.tags.length) {
  post.tags.forEach(function(tag) { tags.push(tag.name); });
}
%>
<article id="post-detail">
  <div class="post-detail-header">
    <div class="post-title">
      <span class="title-marker">&gt; </span><%= post.title || 'Untitled' %>
    </div>
    <div class="post-meta">
      <span class="meta-item"><span class="meta-label">@</span> <%= post.author || config.author %></span>
      <span class="meta-separator gray">|</span>
      <span class="meta-item"><span class="meta-label">date:</span> <%= dateStr %></span>
      <span class="meta-separator gray">|</span>
      <span class="meta-item"><span class="meta-label">cat:</span> <%= categoryStr %></span>
      <% if (tags.length) { %>
      <span class="meta-separator gray">|</span>
      <span class="meta-item"><span class="meta-label">tags:</span> <%= tags.join(', ') %></span>
      <% } %>
    </div>
    <div class="post-divider">========================================</div>
  </div>
  <div class="post-content">
    <%- post.content %>
  </div>
  <div class="post-divider">========================================</div>
  <% if (theme.comment && theme.comment.enable) { %>
  <%- partial('_partial/comment') %>
  <% } %>
</article>
