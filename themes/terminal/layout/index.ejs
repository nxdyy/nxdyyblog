<div id="post-list">
  <div class="list-header">
    <span class="header-label">[Posts]</span>
    <span class="post-count gray"><%= page.posts.length %> article(s)</span>
  </div>
  <div class="list-divider">----------------------------------------</div>
  <% page.posts.forEach(function(post) { %>
  <%- partial('_partial/post-item', { item: post }) %>
  <% }); %>
  <%- partial('_partial/pagination') %>
</div>
