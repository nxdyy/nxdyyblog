<%
var dateStr = page.date ? page.date.format('YYYY-MM-DD HH:mm') : '';
%>
<article id="page-detail">
  <div class="page-detail-header">
    <div class="page-title">
      <span class="title-marker">&gt; </span><%= page.title || 'Untitled' %>
    </div>
    <div class="post-divider">========================================</div>
  </div>
  <div class="page-content">
    <%- page.content %>
  </div>
  <div class="post-divider">========================================</div>
  <% if (theme.comment && theme.comment.enable && page.comments !== false) { %>
  <%- partial('_partial/comment') %>
  <% } %>
</article>
