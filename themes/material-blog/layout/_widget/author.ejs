<!-- 作者信息小工具 -->
<aside id="sidebar-author">
  <div class="sidebar-widget author-widget" data-aos="flip-right" data-aos-duration="3000">
    <md-outlined-card>
      <div class="author-card-header">
        <span class="author-quote">&ldquo;</span>
        <%= config.author %>
        <span class="author-quote">&rdquo;</span>
      </div>
      <div class="author-card-content">
        <img
          src="<%- url_for(/https?:\/\//.test(theme.author_image) ? theme.author_image : `imgs/${theme.author_image}`) %>"
          width="140" height="140"
          alt="个人头像"
          class="author-image"
          loading="lazy">
        <p class="author-name"><%= config.author %></p>
        <p class="author-description"><%- config.description ? markdown(config.description) : "" %></p>
      </div>
    </md-outlined-card>
  </div>
</aside>

<style>
  .author-widget {
    margin-bottom: 16px;
  }
  .author-widget md-outlined-card {
    width: 100%;
    --md-card-container-color: var(--md-sys-color-surface-container-low, #f7f2fa);
  }
  .author-card-header {
    text-align: center;
    padding: 16px 16px 8px;
    font-size: 14px;
    color: var(--md-sys-color-on-surface-variant, #49454f);
    font-weight: 500;
  }
  .author-quote {
    color: var(--md-sys-color-primary, #6750a4);
    font-size: 18px;
  }
  .author-card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 16px 24px;
  }
  .author-image {
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--md-sys-color-primary-container, #eaddff);
    margin-bottom: 12px;
    transition: transform 0.3s ease;
  }
  .author-image:hover {
    transform: scale(1.05);
  }
  .author-name {
    font-size: 18px;
    font-weight: 600;
    color: var(--md-sys-color-on-surface, #1c1b1f);
    margin: 0 0 8px 0;
  }
  .author-description {
    font-size: 13px;
    color: var(--md-sys-color-on-surface-variant, #49454f);
    text-align: center;
    line-height: 1.6;
    margin: 0;
  }
  @media (max-width: 768px) {
    .author-widget {
      display: none;
    }
  }
</style>
