<!-- 最新评论小工具 -->
<aside id="sidebar-recent_comments">
  <div class="sidebar-widget recent-comments-widget" data-aos="fade-up" data-aos-duration="2000">
    <md-outlined-card>
      <div class="widget-header">
        <div class="widget-header-title">
          <span class="material-symbols-outlined widget-header-icon">forum</span>
          <span>最新评论</span>
        </div>
        <div class="widget-header-actions">
          <md-icon-button class="panel-toggle" aria-label="折叠">
            <span class="material-symbols-outlined">expand_less</span>
          </md-icon-button>
          <md-icon-button class="panel-remove" aria-label="关闭">
            <span class="material-symbols-outlined">close</span>
          </md-icon-button>
        </div>
      </div>
      <div class="widget-content">
        <md-list id="recent-comments-list">
          <!-- 评论由评论系统动态填充 -->
        </md-list>
      </div>
    </md-outlined-card>
  </div>
</aside>

<script>
  (function() {
    var toggleBtn = document.querySelector('#sidebar-recent_comments .panel-toggle');
    var removeBtn = document.querySelector('#sidebar-recent_comments .panel-remove');
    var content = document.querySelector('#sidebar-recent_comments .widget-content');
    if (toggleBtn && content) {
      toggleBtn.addEventListener('click', function() {
        var isHidden = content.style.display === 'none';
        content.style.display = isHidden ? '' : 'none';
        var icon = toggleBtn.querySelector('.material-symbols-outlined');
        icon.textContent = isHidden ? 'expand_less' : 'expand_more';
      });
    }
    if (removeBtn) {
      removeBtn.addEventListener('click', function() {
        var widget = document.querySelector('#sidebar-recent_comments .recent-comments-widget');
        if (widget) widget.style.display = 'none';
      });
    }
  })();
</script>

<style>
  .recent-comments-widget {
    margin-bottom: 16px;
  }
  .recent-comments-widget md-outlined-card {
    width: 100%;
    --md-card-container-color: var(--md-sys-color-surface-container-low, #f7f2fa);
  }
  .recent-comments-widget .widget-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--md-sys-color-outline-variant, #cac4d0);
  }
  .recent-comments-widget .widget-header-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--md-sys-color-on-surface, #1c1b1f);
  }
  .recent-comments-widget .widget-header-icon {
    color: var(--md-sys-color-secondary, #625b71);
  }
  .recent-comments-widget .widget-header-actions {
    display: flex;
    align-items: center;
  }
  .recent-comments-widget .widget-content {
    max-height: 300px;
    overflow-y: auto;
  }
  .recent-comments-widget .widget-content md-list {
    padding: 0;
  }
  @media (max-width: 768px) {
    .recent-comments-widget {
      display: none;
    }
  }
</style>
