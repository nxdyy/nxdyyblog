<!-- 文章书签/目录 浮动窗口 -->
<div id="gal-bookmark" class="gal-bookmark-panel" style="display:none;">
    <div class="gal-bookmark-header" id="gal-bookmark-header">
        <span class="gal-bookmark-title">
            <span class="material-symbols-outlined">bookmark</span>
            <span>书签</span>
        </span>
        <span class="gal-bookmark-controls">
            <button class="gal-bookmark-btn" id="gal-bookmark-minimize" title="收起/展开">
                <span class="material-symbols-outlined">remove</span>
            </button>
        </span>
    </div>
    <div class="gal-bookmark-body" id="gal-bookmark-body">
        <ul class="gal-bookmark-list" id="gal-bookmark-list"></ul>
    </div>
</div>
