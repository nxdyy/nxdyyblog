<%
var coverNum = Math.floor(Math.random() * theme.default_preview.length);
var coverImage = item.preview ? item.preview : (/https?:\/\//.test(theme.default_preview[coverNum]) ? theme.default_preview[coverNum] : url_for(`imgs/preview/${theme.default_preview[coverNum]}`));
%>
<% if (!isPage) { %>
<article class="article-card article-body" id="article">
    <div class="article-breadcrumb">
        <a href="<%- config.url %>"><span class="material-symbols-outlined">home</span> <%= config.title %></a>
        <span class="breadcrumb-sep">/</span>
        <span><%= item.title %></span>
    </div>
    <div class="article-cover">
        <img src="<%- coverImage %>" alt="<%= item.title %>">
    </div>
    <div class="article-header">
        <h1 class="article-title">
            <a href="<%- url_for(item.path) %>"><%= item.title %></a>
        </h1>
        <div class="article-meta">
            <% if(item.tags.data.length > 0) { %>
            <span class="article-tag">
                <span class="material-symbols-outlined">label</span>
                <% item.tags.data.forEach(function (tag, index) { %>
                <a href="<%- url_for(tag.path) %>"><%= tag.name %></a><%= index === item.tags.data.length - 1 ? '' : ', ' %>
                <% }) %>
            </span>
            <% } %>
            <span class="article-date">
                <span class="material-symbols-outlined">calendar_today</span> <%= item.date.format('YYYY-MM-DD') %>
            </span>
            <% if(theme.leancloud.appid && theme.leancloud.appkey) { %>
            <span class="article-views">
                <span class="material-symbols-outlined">visibility</span>
            </span>
            <% } %>
        </div>
    </div>
    <md-divider></md-divider>
    <div class="content-article">
        <%- item.content %>
    </div>
</article>
<% } else { %>
<article class="article-card article-body" id="article">
    <div class="article-cover">
        <img src="<%- coverImage %>" alt="<%= item.title %>">
    </div>
    <div class="article-header">
        <h1 class="article-title">
            <a href="<%- url_for(item.path) %>"><%= item.title %></a>
        </h1>
        <div class="article-meta">
            <span class="article-date">
                <span class="material-symbols-outlined">calendar_today</span> <%= item.date.format('YYYY-MM-DD') %>
            </span>
        </div>
    </div>
    <md-divider></md-divider>
    <div class="content-article">
        <%- item.content %>
    </div>
</article>
<% } %>
<% if(theme.use_comment === true) { %>
<div id="comments-template"></div>
<link rel="stylesheet" href="https://imsun.github.io/gitment/style/default.css">
<script>
    if(!window.commentConfig) {
      window.commentConfig = {}
      window.commentConfig.title = '<%= item.title %>'
    }
</script>
<% } %>
<style>
.article-title {
    text-align: center;
}
.article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--md-sys-color-surface-container);
    border-radius: 12px;
    margin-bottom: 20px;
    font-size: 14px;
    color: var(--md-sys-color-on-surface-variant);
}
.article-breadcrumb a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--md-sys-color-primary);
    text-decoration: none;
}
.article-breadcrumb .material-symbols-outlined {
    font-size: 18px;
}
.breadcrumb-sep {
    color: var(--md-sys-color-outline);
}
.article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 12px;
}
.article-meta span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: var(--md-sys-color-on-surface-variant);
}
.article-meta .material-symbols-outlined {
    font-size: 18px;
    color: var(--md-sys-color-primary);
}
</style>
