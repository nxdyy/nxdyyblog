<!-- 侧边栏 -->
<div class="sidebar-column">
  <!-- 作者信息 -->
  <%- partial('_widget/author') %>

  <!-- 最新评论 -->
  <% if (theme.sidebar.recent_comments) { %>
  <%- partial('_widget/recent_comments') %>
  <% } %>

  <!-- 最热文章 (需要配置 LeanCloud) -->
  <% if (theme.sidebar.hot_posts && (theme.leancloud.appid && theme.leancloud.appkey)) { %>
  <%- partial('_widget/hot_posts') %>
  <% } %>

  <!-- 近期文章 -->
  <% if (theme.sidebar.recent_posts) { %>
  <%- partial('_widget/recent_posts') %>
  <% } %>

  <!-- 标签 / 友情链接 / 个人链接 Tab 切换区 -->
  <% if (theme.sidebar.tags === true || theme.sidebar.friend_links === true || theme.sidebar.links === true) { %>
  <aside id="sidebar-tabs">
    <div class="sidebar-widget tabs-widget hidden-xs">
      <div class="tabs-header">
        <% if (theme.sidebar.tags === true) { %>
        <button class="tab-btn active" data-tab="tags">
          <span class="material-symbols-outlined">sell</span>
          <span>热门标签</span>
        </button>
        <% } %>
        <% if (theme.sidebar.friend_links === true) { %>
        <button class="tab-btn" data-tab="friend-links">
          <span class="material-symbols-outlined">group</span>
          <span>友情链接</span>
        </button>
        <% } %>
        <% if (theme.sidebar.links === true) { %>
        <button class="tab-btn" data-tab="links">
          <span class="material-symbols-outlined">link</span>
          <span>个人链接</span>
        </button>
        <% } %>
      </div>

      <div class="tabs-content">
        <% if (theme.sidebar.tags === true) { %>
        <div class="tab-panel" id="panel-tags">
          <%- partial('_widget/hot_tags') %>
        </div>
        <% } %>
        <% if (theme.sidebar.friend_links === true) { %>
        <div class="tab-panel" id="panel-friend-links" style="display:none;">
          <%- partial('_widget/friend_links') %>
        </div>
        <% } %>
        <% if (theme.sidebar.links === true) { %>
        <div class="tab-panel" id="panel-links" style="display:none;">
          <%- partial('_widget/links') %>
        </div>
        <% } %>
      </div>
    </div>
  </aside>
  <% } %>
</div>

<script>
  (function() {
    var btns = document.querySelectorAll('#sidebar-tabs .tab-btn');
    var panels = document.querySelectorAll('#sidebar-tabs .tab-panel');
    if (!btns.length || !panels.length) return;

    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tabName = btn.getAttribute('data-tab');
        btns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        panels.forEach(function(panel) {
          panel.style.display = panel.id === 'panel-' + tabName ? '' : 'none';
        });
      });
    });
  })();
</script>

<style>
  .sidebar-column {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 16px 0;
  }
  .tabs-widget {
    margin-bottom: 16px;
    background: var(--md-sys-color-surface-container-low, #f7f2fa);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--md-sys-color-outline-variant, #cac4d0);
  }
  .tabs-header {
    display: flex;
    border-bottom: 1px solid var(--md-sys-color-outline-variant, #cac4d0);
    overflow-x: auto;
  }
  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    border: none;
    background: transparent;
    color: var(--md-sys-color-on-surface-variant, #49454f);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
    border-bottom: 2px solid transparent;
    font-family: inherit;
  }
  .tab-btn:hover {
    background: var(--md-sys-color-surface-container-high, #ece6f0);
    color: var(--md-sys-color-on-surface, #1c1b1f);
  }
  .tab-btn.active {
    color: var(--md-sys-color-primary, #6750a4);
    border-bottom-color: var(--md-sys-color-primary, #6750a4);
  }
  .tab-btn .material-symbols-outlined {
    font-size: 18px;
  }
  .tabs-content {
    min-height: 80px;
  }
  @media (max-width: 768px) {
    .tabs-widget {
      display: none;
    }
  }
  #sidebar-tabs .tab-panel {
    padding: 16px;
  }
</style>
